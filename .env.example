# Database
DATABASE_URL="file:./db/prod.db"

# Authentication (Auth.js)
AUTH_SECRET="your-secret-key-change-in-production"
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Email
EMAIL_FROM="noreply@crunchycone.app"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Authentication Providers - Enable/Disable (client-accessible)
NEXT_PUBLIC_ENABLE_EMAIL_PASSWORD=true
NEXT_PUBLIC_ENABLE_MAGIC_LINK=true
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=false

# OAuth Providers (optional)
# Google OAuth
# NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true
# GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"

# GitHub OAuth
# NEXT_PUBLIC_ENABLE_GITHUB_AUTH=true
# GITHUB_CLIENT_ID="your-github-client-id"
# GITHUB_CLIENT_SECRET="your-github-client-secret"

CRUNCHYCONE_EMAIL_PROVIDER="console"
CRUNCHYCONE_EMAIL_FROM_DISPLAY="Crunchy Cone"
# Email Provider Configuration (uncomment as needed)
# SENDGRID_API_KEY="your-sendgrid-api-key"
# RESEND_API_KEY="your-resend-api-key"
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_REGION="us-east-1"
# CRUNCHYCONE_SMTP_HOST="smtp.gmail.com"
# CRUNCHYCONE_SMTP_PORT="587"
# CRUNCHYCONE_SMTP_SECURE="false"
# CRUNCHYCONE_SMTP_USER=""
# CRUNCHYCONE_SMTP_PASS=""
#
# Task-based analysis (when USE_TASK_BASED_ANALYSIS=true)
# ANALYSIS_CONCURRENCY=3              # Parallel tasks for steps not covered by batch envs below (e.g. BLOG_NEWS)
# ANALYSIS_SENTIMENT_BATCH_SIZE=20    # Posts per OpenAI call for sentiment (worker groups tasks)
# ANALYSIS_SENTIMENT_CONCURRENCY=5    # Parallel sentiment batches (roughly 5× batch_size posts in flight)
# ANALYSIS_THEMES_CONCURRENCY=5       # Parallel THEMES task batches in worker (legacy batch size for task queue)
# ANALYSIS_THEMES_THREAD_CONCURRENCY=5 # Parallel conversations for theme LLM (one API call per thread)
# ANALYSIS_CHATTER_BATCH_SIZE=20      # Posts per runChatterForPostIds call in worker
# ANALYSIS_CHATTER_CONCURRENCY=5      # Parallel CHATTER batches (each batch = CHATTER_BATCH_SIZE posts)
# ANALYSIS_CHATTER_THREAD_CONCURRENCY=10 # Parallel threads per wave inside storeChatterAnalysis (LLM scoring + persist)
# ANALYSIS_CHATTER_WAVE_DELAY_MS=200   # Pause between waves (rate limiting; 0 = no delay)
# CHATTER_TOP_N_TO_SCORE=100           # Max threads after embedding prefilter (cap 150) before LLM gate
# CHATTER_MIN_SIM_FOR_LLM=0.24         # Skip LLM relevance if cosine(essence,thread) is below (faster on noisy Discord)
# CHATTER_DISCORD_MIN_SIM_FOR_LLM=     # Optional: override min sim for Discord only (e.g. 0.28)
# ANALYSIS_VERBOSE_CHATTER=1           # Per-thread chatter scoring logs (default: off)
# ANALYSIS_NETWORK_CLAIM_LIMIT=5000    # Max NETWORK tasks merged per worker batch (already one runNetworkForPostIds per claim)
# ANALYSIS_NETWORK_WAVE_CONCURRENCY=5  # Parallel influencers per wave in analyzeNetwork (relevance + summarize/upsert)
# ANALYSIS_NETWORK_WAVE_DELAY_MS=800   # Pause between network waves
# ANALYSIS_BRAND_BATCH_SIZE=100       # Posts per BRAND batch in the worker
# ANALYSIS_TASK_LEASE_MS=0            # Reclaim RUNNING tasks older than this (ms); 0 = off. Try 1800000 (30m) if workers crash mid-run
# ANALYSIS_TASK_PENDING_MAX_AGE_HOURS=24  # PENDING analysis tasks older than this (by updated_at) are marked SKIPPED each worker tick; 0 = disable
# ANALYSIS_METRICS_JSON=false         # If true, log JSON lines for idle worker polls (metrics / log sinks)
#
# OpenAI chat models (default: gpt-4o-mini via OPENAI_MODEL). Per-step overrides fall back to OPENAI_MODEL.
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_SENTIMENT_MODEL=
# OPENAI_THEMES_MODEL=
# OPENAI_CHATTER_MODEL=
# OPENAI_NETWORK_MODEL=
# OPENAI_NEWS_MODEL=
# NEWS_SYNTHESIS_MAX_BLOG_POSTS=1500  # Max blog Post rows loaded into memory for news synthesis (default 1500; raise if you have RAM; prevents OOM)
# OPENAI_BRAND_MODEL=
# OPENAI_RELEVANCE_MODEL=
# OPENAI_SUMMARIZE_MODEL=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# See docs/analysis-performance-runbook.md and docs/analysis-claiming.md

# Storage Provider Configuration
CRUNCHYCONE_STORAGE_PROVIDER="localstorage"
CRUNCHYCONE_LOCALSTORAGE_PATH="./uploads"
CRUNCHYCONE_LOCALSTORAGE_BASE_URL="/api/storage/files"

# Hacker News keyword ingestion (Algolia search_by_date + optional Firebase enrichment)
# HN_INGEST_KEYWORDS="cybersecurity,agents"
# HN_KEYWORD_VARIANTS_JSON='{"cybersecurity":["cybersecurity","infosec"]}'
# Or: HN_KEYWORD_VARIANTS_JSON="./config/hn-keyword-variants.json"
# HN_ENRICH_STORIES=true
# Set to false to skip storing Algolia comment hits (stories only); comment themes still sync via Firebase when enabled.
# HN_INGEST_ALGOLIA_COMMENTS=true
# Cap Firebase+LLM comment-theme sync per ingest batch (omit = all distinct stories in batch; 0 = off).
# HN_COMMENT_THEME_SYNC_MAX=
# Parallel comment-theme syncs (Firebase + LLM per story). Default 10. Max 50.
# HN_COMMENT_THEME_SYNC_CONCURRENCY=10

# HN comment-thread + HnStoryAnalysis comment summary model (OpenAI Chat Completions). Default gpt-4o-mini.
# OPENAI_HN_MODEL=gpt-4o-mini

# HN story analysis (Firebase threads + OpenAI; uses OPENAI_API_KEY). CLI: npm run hn-story-analysis
# Optional: HN_STORY_IDS="123,456" with scripts/run-hn-story-analysis.ts to force specific story ids
# Parallel HN story analyses (Firebase + LLM per story). Default 10. Max 50.
# HN_STORY_ANALYSIS_CONCURRENCY=10

# GitHub keyword ingestion (REST search; requires GITHUB_TOKEN)
# GITHUB_TOKEN="ghp_..."
# GH_INGEST_KEYWORDS="security,agents"
# GH_KEYWORD_VARIANTS_JSON='{".env":["dotenv","environment variables"]}'
# GH_INGEST_MODES="repo,code"
# GH_CODE_LOOKBACK_DAYS=7
# GH_ENRICH_REPOS=true
# Parallel GitHub repo enrichment (structured summary). Default 4; max 16. Use 1 for strict serial + delay.
# GITHUB_ENRICH_CONCURRENCY=4

# Discord scraper (Apify): bot token is injected at runtime — do not put it in scraper config_json in the DB.
# DISCORD_BOT_TOKEN="your-discord-bot-token"

# Orchestration: custom tasks (Hacker News, GitHub Reader, etc.) run in-process — wall-clock limit (default 3 h). Set to 0 to disable timeout (not recommended).
# ORCHESTRATION_CUSTOM_TASK_TIMEOUT_MS=10800000
# Reconciliation marks RUNNING custom steps FAILED if older than this (default: timeout + 15 min). Crash/hang recovery.
# ORCHESTRATION_STALE_CUSTOM_STEP_MS=3600000

# LinkedIn prospects CSV (GET /api/projects/[id]/linkedin-prospects-export) — /reports/email
# Query: rangeAmount=1-31&rangeUnit=days|weeks|months&minRelevancePercent=0-100
# LINKEDIN_PROSPECTS_CSV_OUTPUT_DIR="/absolute/path/to/linkedin-pipeline/inbox"
# LINKEDIN_PROSPECTS_CSV_MAX_ROWS=100

# LinkedIn profile Experience acquisition (not post scraper; full profile + experience[])
# APIFY_API_TOKEN required for Apify path (same token as orchestration scrapers)
# LINKEDIN_PROFILE_EXPERIENCE_APIFY_ACTOR_ID="your-apify-actor-id"
# LINKEDIN_PROFILE_EXPERIENCE_PROVIDER=apify,html
# LINKEDIN_PROFILE_EXPERIENCE_COST_PER_PROFILE_USD=0.005
# Legacy OpenAI inference disabled by default (set to 1 only for experiments)
# LINKEDIN_PROFILE_EXPERIENCE_ALLOW_OPENAI_INFERENCE=0
