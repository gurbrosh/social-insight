    "enrich-brands-blog-news": "npx tsx scripts/enrich-project-brands-blog-news.ts",
    "hn-ingest": "npx tsx scripts/run-hn-keyword-ingestion.ts",
    "hn-clear-tables": "npx tsx scripts/clear-hn-tables.ts",
    "hn-clear-project": "npx tsx scripts/clear-hn-for-project.ts",
    "cleanup:stale-analysis": "npx tsx scripts/cleanup-stale-analysis-runs.ts",
    "cancel-project-analysis": "npx tsx scripts/cancel-project-analysis.ts",
    "hn-story-analysis": "npx tsx scripts/run-hn-story-analysis.ts",
    "verify:hn-tree": "npx tsx scripts/verify-hn-story-comment-tree.ts",
    "gh-ingest": "npx tsx scripts/run-github-keyword-ingestion.ts",
    "github:backfill-product-relevance": "npx tsx scripts/backfill-github-product-relevance.ts",
    "response:clear": "npx tsx scripts/clear-theme-item-responses.ts --all",
    "analysis:worker": "npx tsx scripts/run-analysis-worker.ts",
